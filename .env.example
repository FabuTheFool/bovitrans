# ============================================================================
# .env.example — BoviTrans
# ============================================================================
# Copiá este archivo a .env y ajustá según tu entorno:
#   cp .env.example .env
# ============================================================================

# ─── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_USER=bovitrans
POSTGRES_PASSWORD=bovitrans_dev
POSTGRES_DB=bovitrans

# ─── App ────────────────────────────────────────────────────────────────────
APP_PORT=3000

# ─── Servicios externos (defaults razonables) ──────────────────────────────
# OSRM público: estable pero rate-limited. Para producción, hostear propio.
OSRM_BASE_URL=https://router.project-osrm.org

# Nominatim público de OSM. Requerimos User-Agent en los headers (configurado
# en código). Para producción, hostear propio o usar una alternativa paga.
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org

# Tiles del mapa (Leaflet). Para producción, considerar un proveedor con SLA.
NEXT_PUBLIC_TILES_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# Moneda por defecto para los importes mostrados en la UI.
# PYG = Guaraní paraguayo.
NEXT_PUBLIC_DEFAULT_CURRENCY=PYG

# ─── Autenticación ──────────────────────────────────────────────────────────
# JWT_SECRET: clave para firmar tokens HS256. MÍNIMO 32 caracteres.
# Generar SIEMPRE con un valor único por entorno:
#   openssl rand -base64 48
# Nunca commitear el valor real; este placeholder rompe el arranque a propósito.
JWT_SECRET=CHANGE_ME_run_openssl_rand_base64_48

# COOKIE_SECURE: pasar la cookie de sesión solo sobre HTTPS.
# Por defecto false (para demo local sobre HTTP). En cualquier deploy real
# detrás de TLS: COOKIE_SECURE=true.
COOKIE_SECURE=false

# Usuarios pre-seedeados (sólo para desarrollo / demo, NO usar en producción):
#   admin@bovitrans.local    / BoviTrans2026!
#   operador@bovitrans.local / Operador2026!
