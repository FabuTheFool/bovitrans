# ============================================================================
# .env.example — BoviTrans
# ============================================================================
# Copiá este archivo a .env y ajustá según tu entorno:
#   cp .env.example .env
# ============================================================================

# ─── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_USER=bovitrans
POSTGRES_PASSWORD=bovitrans_dev
POSTGRES_DB=bovitrans

# ─── App ────────────────────────────────────────────────────────────────────
APP_PORT=3000

# ─── Servicios externos (defaults razonables) ──────────────────────────────
# OSRM público: estable pero rate-limited. Para producción, hostear propio.
OSRM_BASE_URL=https://router.project-osrm.org

# Nominatim público de OSM. Requerimos User-Agent en los headers (configurado
# en código). Para producción, hostear propio o usar una alternativa paga.
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org

# Tiles del mapa (Leaflet). Para producción, considerar un proveedor con SLA.
NEXT_PUBLIC_TILES_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# Moneda por defecto para los importes mostrados en la UI.
NEXT_PUBLIC_DEFAULT_CURRENCY=UYU
